{
  "name": "datapilot",
  "description": "AI-native database workspace for developers, analysts, and teams.",
  "private": true,
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/csap-ai/datapilot.git"
  },
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "dev": "pnpm dev:web",
    "dev:web": "pnpm --filter @datapilot/web dev",
    "build:web": "pnpm --filter @datapilot/web build",
    "dev:api": "go run ./apps/api/cmd/api",
    "build:api": "go build -o ./bin/datapilot-api ./apps/api/cmd/api",
    "dev:desktop": "cd apps/desktop && wails dev",
    "build:desktop": "cd apps/desktop && wails build",
    "build": "pnpm build:web && pnpm build:api"
  }
}
